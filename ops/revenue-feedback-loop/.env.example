# Cloudflare R2 credentials for a bucket-scoped token.
# Use a separate token for this worker. Read-only is enough unless REPORT_R2_PREFIX is enabled.
R2_ACCOUNT_ID=677b373460621c1d9ac6dc7ffb4de2f3
R2_ENDPOINT_URL=https://677b373460621c1d9ac6dc7ffb4de2f3.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ezcar24-revenuecat-exports
R2_REVENUECAT_PREFIX=revenuecat/transactions_v2/

# Optional Apple Ads CSV ingestion. Export Search Results data from Apple Ads and put CSVs here.
APPLE_ADS_CSV_DIR=./data/apple-ads

# Optional: read Apple Ads CSV files from the same R2 bucket.
APPLE_ADS_R2_PREFIX=

# Optional: upload generated reports back to R2. Requires a write-capable R2 token.
REPORT_R2_PREFIX=

STATE_DIR=./state
REPORT_DIR=./reports
LOOKBACK_DAYS=30
REPORT_RETENTION_DAYS=90
APPLE_ADS_CSV_RETENTION_DAYS=180

# Recommendation thresholds. This worker only reports recommendations; it does not change Apple Ads.
MIN_SPEND_FOR_ACTION=10
SCALE_ROAS_THRESHOLD=1.25
CUT_ROAS_THRESHOLD=0.35
MIN_REVENUE_FOR_SCALE=5
