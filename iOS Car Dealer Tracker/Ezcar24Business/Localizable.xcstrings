    "Based on aging and market conditions, consider a price reduction to accelerate sale." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بناءً على مدة بقاء المركبة وظروف السوق، فكّر في خفض السعر لتسريع البيع."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Based on aging and market conditions, consider a price reduction to accelerate sale."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उम्र बढ़ने और बाजार की स्थितियों के आधार पर, बिक्री में तेजी लाने के लिए कीमत में कमी पर विचार करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在庫期間と市場状況を踏まえ、販売を早めるための値下げを検討してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "С учетом срока и рынка рассмотрите снижение цены, чтобы ускорить продажу."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turib qolish muddati va bozor sharoitiga qarab sotuvni tezlashtirish uchun narxni pasaytirishni ko‘rib chiqing."
          }
        }
      }
    },
