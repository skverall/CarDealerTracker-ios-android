      }
    },
    "This password is shown once. Share it securely and ask the member to change it after signing in." : {
      "comment" : "A footer message explaining the security of the generated password.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم عرض كلمة المرور هذه مرة واحدة. شاركها بشكل آمن واطلب من العضو تغييرها بعد تسجيل الدخول."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This password is shown once. Share it securely and ask the member to change it after signing in."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह पासवर्ड एक बार दिखाया जाता है. इसे सुरक्षित रूप से साझा करें और साइन इन करने के बाद सदस्य से इसे बदलने के लिए कहें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このパスワードは一度だけ表示されます。安全な方法で共有し、サインイン後に変更するようメンバーへ依頼してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот пароль показывается один раз. Передайте его безопасно и попросите участника изменить после входа."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ushbu parol bir marta koʻrsatiladi. Uni xavfsiz ulashing va tizimga kirganingizdan keyin aʻzodan uni oʻzgartirishni soʻrang."
          }
        }
      }
    },
    "This VIN is already in your inventory." : {
      "comment" : "An in-app message that appears when a user tries to add a vehicle with a duplicate VIN.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "رقم VIN هذا موجود بالفعل في مخزونك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This VIN is already in your inventory."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह VIN पहले से ही आपकी सूची में है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このVINはすでに在庫に登録されています。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот VIN уже есть в вашем инвентаре."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu VIN allaqachon inventaringizga kiritilgan."
          }
        }
      }
    },
    "This will permanently delete your account and all data." : {
      "comment" : "A description of what happens when the user deletes their account.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف حسابك وجميع البيانات بشكل دائم."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete your account and all data."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इससे आपका खाता और सारा डेटा स्थायी रूप से हटा दिया जाएगा."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントとすべてのデータが完全に削除されます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это действие безвозвратно удалит ваш аккаунт и все данные."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu sizning hisobingiz va barcha maʻlumotlarni butunlay oʻchirib tashlaydi."
          }
        }
      }
    },
    "This will remove the debt and all its payments." : {
      "comment" : "A message displayed when a user attempts to delete a debt. It explains that deleting the debt will also delete all of its payments.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى إزالة الديون وجميع مدفوعاتها."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will remove the debt and all its payments."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इससे कर्ज और उसके सभी भुगतान दूर हो जाएंगे।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "債務と関連するすべての支払いを削除します。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это удалит долг и все его платежи."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu qarzni va uning barcha toʻlovlarini olib tashlaydi."
          }
        }
      }
    },
    "This will save the current category, vehicle, user, and account as a template." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حفظ الفئة الحالية والمركبة والمستخدم والحساب كقالب."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will save the current category, vehicle, user, and account as a template."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह वर्तमान श्रेणी, कार, उपयोगकर्ता और खाते को एक टेम्पलेट के रूप में सहेजेगा।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在のカテゴリ、車両、ユーザー、口座をテンプレートとして保存します。"
