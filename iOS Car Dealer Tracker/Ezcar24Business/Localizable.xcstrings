    "Generic fee line is optional. Enter it only if you collect fees." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خط الرسوم العام اختياري. أدخله فقط إذا قمت بتحصيل الرسوم."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generic fee line is optional. Enter it only if you collect fees."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "汎用テンプレートの諸費用行は任意です。諸費用を徴収する場合のみ入力してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
