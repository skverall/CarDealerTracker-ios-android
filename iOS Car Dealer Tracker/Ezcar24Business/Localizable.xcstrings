          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ की जाँच करें। आपकी खाता सुरक्षा सेटिंग्स के आधार पर, आपको अपने वर्तमान और नए ईमेल पते दोनों से परिवर्तन की पुष्टि करने की आवश्यकता हो सकती है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Periksa %@. Tergantung pada pengaturan keamanan akun Anda, Anda mungkin perlu mengonfirmasi perubahan dari alamat email Anda saat ini dan yang baru."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check %@. Depending on your account security settings, you may need to confirm the change from both your current and new email addresses."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verifique %@. Dependendo das configurações de segurança da sua conta, talvez seja necessário confirmar a alteração nos seus endereços de e-mail atuais e novos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проверьте %@. В зависимости от настроек безопасности аккаунта может потребоваться подтверждение с текущего и нового email."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ tekshiring. Hisobingizning xavfsizlik sozlamalariga qarab, joriy va yangi elektron pochta manzillaringizdan oʻzgarishlarni tasdiqlashingiz kerak boʻlishi mumkin."
          }
        }
      }
    },
