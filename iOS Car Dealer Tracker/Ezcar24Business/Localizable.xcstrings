    "feedback_board_prompt_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف أفكارك، وصوّت للطلبات، وساعدنا في تحديد أولويات التحديثات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add ideas, vote for requests, and help prioritize updates."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "विचार जोड़ें, अनुरोधों के लिए वोट करें और अपडेट को प्राथमिकता देने में सहायता करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイデアを追加し、要望に投票して、更新の優先順位決めに参加できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아이디어를 추가하고 요청에 투표해 업데이트 우선순위를 정하는 데 참여하세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавляйте идеи, голосуйте за запросы и помогайте выбирать приоритеты обновлений."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gʻoyalar qoʻshing, soʻrovlarga ovoz bering va yangilanishlarni ustuvor qiling."
