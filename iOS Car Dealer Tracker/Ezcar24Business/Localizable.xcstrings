        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "होल्डिंग लागत कुल लागत का %@%% है। तेज़ टर्नओवर पर विचार करें."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保有コストは総コストの%@%%です。より早い回転を検討してください。"
