    "guest_preview_expenses_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعرف على كيفية تجميع المصروفات حسب المركبة والموظف والفئة والتاريخ دون إدخال بيانات عمل حقيقية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "See how expenses are grouped by vehicle, employee, category, and date without entering real business data."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "देखें कि वास्तविक व्यावसायिक डेटा दर्ज किए बिना खर्चों को कार, कर्मचारी, श्रेणी और तारीख के आधार पर कैसे समूहीकृत किया जाता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lihat bagaimana pengeluaran dikelompokkan berdasarkan kendaraan, karyawan, kategori, dan tanggal tanpa memasukkan data bisnis nyata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "実際の業務データを入力せずに、経費が車両・担当者・カテゴリ・日付別に集計される様子を確認できます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veja como as despesas são agrupadas por veículo, funcionário, categoria e data sem inserir dados comerciais reais."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Посмотрите, как расходы группируются по авто, сотруднику, категории и дате без ввода реальных данных."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haqiqiy biznes ma'lumotlarini kiritmasdan xarajatlar avtomobil, xodim, toifa va sana boʻyicha qanday guruhlanganligini koʻring."
          }
