      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ستتم إزالة فكرتك من اللوحة. لا يمكن حذف الأفكار المكتملة."
          }
        },
        "en" : {
          "stringUnit" : {
