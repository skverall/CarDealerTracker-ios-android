    "If signed in, the archive also uploads to Supabase (bucket: dealer-backups) for cloud recovery." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "في حالة تسجيل الدخول، يتم تحميل الأرشيف أيضًا إلى Supabase (الحاوية: النسخ الاحتياطية للموزع) للاسترداد السحابي."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If signed in, the archive also uploads to Supabase (bucket: dealer-backups) for cloud recovery."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि साइन इन किया गया है, तो संग्रह क्लाउड रिकवरी के लिए Supabase (बकेट: डीलर-बैकअप) पर भी अपलोड होता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サインインしている場合、復元用にアーカイブもSupabase（dealer-backupsバケット）へアップロードされます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы вошли в систему, архив также загружается в Supabase (корзина: dealer-backups) для облачного восстановления."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agar tizimga kirgan boʻlsangiz, arxiv bulutni tiklash uchun Supabase’ga ham yuklanadi (paqir: diler-zaxira)."
          }
        }
      }
    },
