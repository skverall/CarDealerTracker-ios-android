    "Vehicle has been in inventory for %lld days. Consider aggressive pricing." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المركبة موجودة في المخزون منذ %lld يومًا. فكّر في تسعير أكثر تنافسية."
          }
