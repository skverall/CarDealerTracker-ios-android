        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فتح مخزون غير محدود، والربح لكل مركبة، والمزامنة السحابية، والتقارير."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock unlimited inventory, profit per vehicle, cloud sync, and reports."
