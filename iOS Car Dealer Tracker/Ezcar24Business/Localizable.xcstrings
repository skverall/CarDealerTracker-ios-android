        "ar" : { "stringUnit" : { "state" : "translated", "value" : "الهامش سلبي في النطاق المختار. راجع التسعير والتكاليف قبل إضافة مخزون جديد." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Margin is negative in the selected range. Review pricing and costs before adding more stock." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "चयनित अवधि में मार्जिन नकारात्मक है. नया स्टॉक जोड़ने से पहले कीमत और लागत देखें." } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Margin negatif pada rentang ini. Tinjau harga dan biaya sebelum menambah stok." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "選択期間の利益率がマイナスです。在庫追加前に価格とコストを確認しましょう。" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "A margem está negativa no período. Revise preços e custos antes de adicionar estoque." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Маржа в выбранном периоде отрицательная. Проверьте цены и расходы перед новым закупом." } },
        "uz" : { "stringUnit" : { "state" : "translated", "value" : "Tanlangan davrda marja manfiy. Yangi ombor qo‘shishdan oldin narx va xarajatlarni tekshiring." } }
      }
    },
