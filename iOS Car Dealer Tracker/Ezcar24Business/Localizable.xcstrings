    "You can buy now as a guest. Sign in only if you want to sync or restore purchases on other devices." : {
      "comment" : "A description under the \"Sign In (Optional)\" button in the paywall, explaining that signing in is optional and only needed if the user wants to sync or restore purchases on other devices.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك الشراء الآن كضيف. قم بتسجيل الدخول فقط إذا كنت تريد مزامنة المشتريات أو استعادتها على الأجهزة الأخرى."
          }
        },
        "en" : {
          "stringUnit" : {
