    "guest_preview_sales_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بمعاينة الإيرادات والودائع والأرباح وتاريخ المركبات المباعة قبل تسجيل صفقة حقيقية."
