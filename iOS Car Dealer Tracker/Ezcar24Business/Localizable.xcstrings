        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내 아이디어가 보드에서 제거됩니다. 완료된 아이디어는 계속 표시됩니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваша идея исчезнет с доски. Выполненные идеи остаются видимыми."
