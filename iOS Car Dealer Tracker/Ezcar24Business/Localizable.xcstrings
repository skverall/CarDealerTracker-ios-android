    "guest_account_required_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وضع الضيف مخصص للعرض فقط. قم بالتسجيل لإضافة المخزون والمصروفات والمبيعات والعملاء والحفاظ على مزامنة بياناتك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guest mode is for viewing only. Sign up to add inventory, expenses, sales, clients, and keep your data synced."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ゲストモードは閲覧専用です。在庫、経費、販売、顧客を追加し同期するには登録してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Гостевой режим только для просмотра. Зарегистрируйтесь, чтобы добавлять авто, расходы, продажи, клиентов и синхронизировать данные."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mehmon rejimi faqat koʻrish uchun. Inventarizatsiya, xarajatlar, savdolar, mijozlarni qoʻshish va ma'lumotlaringizni sinxronlashtirish uchun roʻyxatdan oʻting."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "गेस्ट मोड केवल देखने के लिए है। इन्वेंट्री, खर्च, बिक्री, ग्राहक जोड़ने और अपना डेटा सिंक रखने के लिए साइन अप करें।"
          }
        }
      }
    },
