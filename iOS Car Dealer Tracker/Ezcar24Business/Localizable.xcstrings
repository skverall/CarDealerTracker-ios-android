    "invite_dealer_subtitle" : {
      "comment" : "Referral explanation text.",
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بإعطاء أصدقائك الموزعين رمز دعوة. تحصل على شهر مجاني عند الاشتراك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Give your dealer friends an invite code. You get 1 month free when they subscribe."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने डीलर मित्रों को एक आमंत्रण कोड दें। जब वे सदस्यता लेते हैं तो आपको 1 महीना मुफ़्त मिलता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berikan kode undangan kepada teman dealer Anda. Anda mendapatkan 1 bulan gratis ketika mereka berlangganan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "販売店仲間に招待コードを共有しましょう。相手が登録すると1か月無料になります。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dê aos seus amigos revendedores um código de convite. Você ganha 1 mês grátis quando eles assinam."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дайте друзьям‑дилерам код. Вы получаете 1 месяц бесплатно, когда они оформят подписку."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dilerlaringizga taklif kodini bering. Ular obuna boʻlganda, siz 1 oy bepul olasiz."
          }
        }
      }
    },
    "invite_existing_account_notice" : {
      "extractionState" : "manual",
      "localizations" : {
