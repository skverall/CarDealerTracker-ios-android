        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте безлимитный инвентарь, прибыль по каждой машине, облачную синхронизацию и отчеты."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cheksiz inventar, har bir avtomobildan foyda, bulutli sinxronizatsiya va hisobotlarni faollashtiring."
