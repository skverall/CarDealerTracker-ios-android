          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This affects currency formatting and distance units"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह मुद्रा स्वरूपण और दूरी इकाइयों को प्रभावित करता है"
          }
        },
        "ja" : {
          "stringUnit" : {
