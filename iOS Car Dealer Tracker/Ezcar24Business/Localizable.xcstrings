          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueie estoque ilimitado, lucro por veículo, sincronização na nuvem e relatórios."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте безлимитный инвентарь, прибыль по каждой машине, облачную синхронизацию и отчеты."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
