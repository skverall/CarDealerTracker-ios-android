    "Check %@. Depending on your account security settings, you may need to confirm the change from both your current and new email addresses." : {
      "comment" : "A paragraph explaining the purpose of the pending email confirmation.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحقق من %@. اعتمادًا على إعدادات أمان حسابك، قد تحتاج إلى تأكيد التغيير من عناوين بريدك الإلكتروني الحالية والجديدة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check %@. Depending on your account security settings, you may need to confirm the change from both your current and new email addresses."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check %@. Depending on your account security settings, you may need to confirm the change from both your current and new email addresses."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проверьте %@. В зависимости от настроек безопасности аккаунта может потребоваться подтверждение с текущего и нового email."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ tekshiring. Hisobingizning xavfsizlik sozlamalariga qarab, joriy va yangi elektron pochta manzillaringizdan oʻzgarishlarni tasdiqlashingiz kerak boʻlishi mumkin."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ की जाँच करें। आपकी खाता सुरक्षा सेटिंग्स के आधार पर, आपको अपने वर्तमान और नए ईमेल पते दोनों से परिवर्तन की पुष्टि करने की आवश्यकता हो सकती है।"
          }
        }
      }
    },
    "Check your inbox to confirm your email change." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحقق من بريدك الوارد لتأكيد تغيير البريد الإلكتروني."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check your inbox to confirm your email change."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メール変更を確認するために受信箱を確認してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проверьте почту, чтобы подтвердить изменение email."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Email oʻzgarishini tasdiqlash uchun pochtangizni tekshiring."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने ईमेल परिवर्तन की पुष्टि करने के लिए अपना इनबॉक्स जांचें।"
          }
        }
      }
    },
    "Check your inbox. Depending on your account security settings, you may need to confirm the change from both your current and new email addresses." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحقق من بريدك الوارد. حسب إعدادات أمان حسابك، قد تحتاج إلى تأكيد التغيير من بريدك الحالي والجديد معًا."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check your inbox. Depending on your account security settings, you may need to confirm the change from both your current and new email addresses."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "受信箱を確認してください。アカウントのセキュリティ設定によっては、現在のメールアドレスと新しいメールアドレスの両方で確認が必要です。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проверьте почту. В зависимости от настроек безопасности аккаунта может понадобиться подтвердить изменение и со старого, и с нового email."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pochtangizni tekshiring. Hisob xavfsizlik sozlamalariga qarab, oʻzgarishni eski va yangi email manzillaringizdan tasdiqlashingiz kerak boʻlishi mumkin."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपना इनबॉक्स जांचें. आपकी खाता सुरक्षा सेटिंग्स के आधार पर, आपको अपने वर्तमान और नए ईमेल पते दोनों से परिवर्तन की पुष्टि करने की आवश्यकता हो सकती है।"
          }
        }
      }
    },
