    "Preview and export the same finance snapshot that will back future email delivery." : {
      "comment" : "A description of the purpose of the monthly report emails.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بمعاينة وتصدير نفس اللقطة المالية التي ستدعم تسليم البريد الإلكتروني في المستقبل."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preview and export the same finance snapshot that will back future email delivery."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उसी वित्त स्नैपशॉट का पूर्वावलोकन करें और निर्यात करें जो भविष्य में ईमेल डिलीवरी का समर्थन करेगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pratinjau dan ekspor cuplikan keuangan yang sama yang akan mendukung pengiriman email di masa mendatang."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今後のメール配信に使う財務スナップショットをプレビューして書き出します。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
