    "guest_preview_dashboard_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تصفح علامات التبويب الرئيسية باستخدام بيانات الوكالة النموذجية. قم بإنشاء حساب عندما تكون مستعدًا لحفظ السجلات الحقيقية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Browse the main tabs with sample dealership data. Create an account when you are ready to save real records."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नमूना डीलरशिप डेटा के साथ मुख्य टैब ब्राउज़ करें। जब आप वास्तविक रिकॉर्ड सहेजने के लिए तैयार हों तो एक खाता बनाएं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Telusuri tab utama dengan contoh data dealer. Buat akun saat Anda siap menyimpan catatan nyata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サンプル販売店データで主要タブを確認できます。実データを保存する準備ができたらアカウントを作成してください。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navegue pelas guias principais com exemplos de dados da concessionária. Crie uma conta quando estiver pronto para salvar registros reais."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте основные вкладки с демо-данными дилера. Создайте аккаунт, когда будете готовы сохранять реальные записи."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Namuna dilerlik ma'lumotlari bilan asosiy yorliqlarni koʻrib chiqing. Haqiqiy yozuvlarni saqlashga tayyor boʻlganingizda hisob yarating."
          }
        }
      }
    },
