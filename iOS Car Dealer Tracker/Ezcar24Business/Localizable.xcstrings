        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Create an account to continue"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "続行するにはアカウントを作成してください"
          }
        },
        "ru" : {
