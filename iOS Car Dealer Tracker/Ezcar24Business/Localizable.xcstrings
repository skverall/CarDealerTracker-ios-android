    "guest_preview_sales_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بمعاينة الإيرادات والودائع والأرباح وتاريخ المركبات المباعة قبل تسجيل صفقة حقيقية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preview revenue, deposits, profit, and sold vehicle history before recording a real deal."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वास्तविक सौदा रिकॉर्ड करने से पहले राजस्व, जमा, लाभ और बेचे गए कार के इतिहास का पूर्वावलोकन करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "実際の販売を記録する前に、売上、入金、利益、販売済み車両履歴を確認できます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Посмотрите выручку, депозиты, прибыль и историю проданных авто перед записью реальной сделки."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haqiqiy bitimni yozishdan oldin daromad, depozitlar, foyda va sotilgan avtomobil tarixini koʻrib chiqing."
          }
        }
      }
    },
