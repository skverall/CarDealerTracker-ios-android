    "This password is shown once. Share it securely and ask the member to change it after signing in." : {
      "comment" : "A footer message explaining the security of the generated password.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم عرض كلمة المرور هذه مرة واحدة. شاركها بشكل آمن واطلب من العضو تغييرها بعد تسجيل الدخول."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This password is shown once. Share it securely and ask the member to change it after signing in."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह पासवर्ड एक बार दिखाया जाता है. इसे सुरक्षित रूप से साझा करें और साइन इन करने के बाद सदस्य से इसे बदलने के लिए कहें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kata sandi ini ditampilkan satu kali. Bagikan dengan aman dan minta anggota untuk mengubahnya setelah masuk."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このパスワードは一度だけ表示されます。安全な方法で共有し、サインイン後に変更するようメンバーへ依頼してください。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta senha é mostrada uma vez. Compartilhe-o com segurança e peça ao membro para alterá-lo após fazer login."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот пароль показывается один раз. Передайте его безопасно и попросите участника изменить после входа."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ushbu parol bir marta koʻrsatiladi. Uni xavfsiz ulashing va tizimga kirganingizdan keyin aʻzodan uni oʻzgartirishni soʻrang."
          }
        }
      }
    },
    "This will permanently delete your account and all data." : {
