        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ईमेल परिवर्तन का अनुरोध किया गया था, लेकिन शेष Proफ़ाइल सहेजी नहीं जा सकी. Proफ़ाइल को दोबारा खोलें और विवरण सत्यापित करें।"
          }
        }
