    "referral_invite_share_message" : {
      "comment" : "Referral invite share sheet message. Placeholder is the invite code.",
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انضم إلى Car Dealer Tracker باستخدام رمز الدعوة الخاص بي %@. اشترك وسيحصل كلانا على شهر إضافي مجانًا."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Join Car Dealer Tracker using my invite code %@. Subscribe and we both get an extra month free."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मेरे आमंत्रण कोड %@ का उपयोग करके Car Dealer Tracker से जुड़ें। सदस्यता लें और हम दोनों को एक अतिरिक्त महीना मुफ़्त मिलेगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bergabunglah dengan Car Dealer Tracker menggunakan kode undangan saya %@. Berlangganan dan kami berdua mendapat satu bulan ekstra gratis."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "招待コード%@でCar Dealer Trackerに参加してください。サブスクリプション登録で、双方に1か月分が追加されます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Junte-se ao Car Dealer Tracker usando meu código de convite %@. Assine e ambos ganharemos um mês extra grátis."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Присоединяйтесь к Car Dealer Tracker по моему коду приглашения %@. Оформите подписку, и мы оба получим дополнительный месяц бесплатно."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taklif kodim %@ yordamida Car Dealer Tracker kompaniyasiga qoʻshiling. Obuna boʻling va ikkalamiz ham qoʻshimcha oy bepul olamiz."
          }
        }
      }
    },
