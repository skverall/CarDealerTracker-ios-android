    "1. Ask team admin for the Team Invite Code." : {
      "comment" : "A step in the process of joining a team, describing the first action to take.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. اطلب من مسؤول الفريق الحصول على رمز دعوة الفريق."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
