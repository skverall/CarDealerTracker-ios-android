        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아이디어를 추가하고 요청에 투표해 업데이트 우선순위를 정하는 데 참여하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione ideias, vote em solicitações e ajude a priorizar atualizações."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавляйте идеи, голосуйте за запросы и помогайте выбирать приоритеты обновлений."
