        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qoʻshmoqchi boʻlgan fotosuratlarga teging. Muqova fotosurati mavjud boʻlganda ham kartani oldindan koʻrish uchun ishlatiladi."
