          "stringUnit" : {
            "state" : "translated",
            "value" : "असीमित इन्वेंट्री, प्रति कार लाभ, क्लाउड सिंक और रिपोर्ट अनलॉक करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
