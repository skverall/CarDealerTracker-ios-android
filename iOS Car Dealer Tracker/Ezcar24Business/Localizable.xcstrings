    "guest_preview_clients_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بمعاينة العملاء المتوقعين والتذكيرات واختبارات القيادة وسجل المتابعة قبل إنشاء نظام إدارة علاقات العملاء (CRM) الخاص بك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preview leads, reminders, test drives, and follow-up history before you create your own CRM."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपना खुद का CRM बनाने से पहले पूर्वावलोकन लीड, रिमाइंडर, टेस्ट ड्राइव और फॉलो-अप इतिहास का पूर्वावलोकन करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pratinjau prospek, pengingat, uji coba, dan riwayat tindak lanjut sebelum Anda membuat CRM Anda sendiri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CRMを作成する前に、リード、リマインダー、試乗、フォロー履歴を確認できます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visualize leads, lembretes, test drives e histórico de acompanhamento antes de criar seu próprio CRM."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Посмотрите лиды, напоминания, тест-драйвы и историю общения перед созданием своей CRM."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oʻz CRM-ingizni yaratishdan oldin lidlar, eslatmalar, test-drayvlar va keyingi aloqalar tarixini koʻrib chiqing."
          }
        }
      }
    },
