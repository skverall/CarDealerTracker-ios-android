    "Only owner or admin can change these settings." : {
      "comment" : "A message displayed in the footer of the Deal Desk settings view, explaining that only the owner or an admin can change the settings.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن للمالك أو المسؤول فقط تغيير هذه الإعدادات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only owner or admin can change these settings."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この設定を変更できるのはオーナーまたは管理者のみです。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Изменять эти настройки может только владелец или администратор."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu sozlamalarni faqat egasi yoki administrator oʻzgartirishi mumkin."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "केवल स्वामी या व्यवस्थापक ही इन सेटिंग्स को बदल सकते हैं."
