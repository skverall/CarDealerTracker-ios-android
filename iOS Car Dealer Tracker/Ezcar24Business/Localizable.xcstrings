    "This password is shown once. Share it securely and ask the member to change it after signing in." : {
      "comment" : "A footer message explaining the security of the generated password.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم عرض كلمة المرور هذه مرة واحدة. شاركها بشكل آمن واطلب من العضو تغييرها بعد تسجيل الدخول."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This password is shown once. Share it securely and ask the member to change it after signing in."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このパスワードは一度だけ表示されます。安全な方法で共有し、サインイン後に変更するようメンバーへ依頼してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот пароль показывается один раз. Передайте его безопасно и попросите участника изменить после входа."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ushbu parol bir marta koʻrsatiladi. Uni xavfsiz ulashing va tizimga kirganingizdan keyin aʻzodan uni oʻzgartirishni soʻrang."
          }
        }
      }
    },
    "This VIN is already in your inventory." : {
      "comment" : "An in-app message that appears when a user tries to add a vehicle with a duplicate VIN.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "رقم VIN هذا موجود بالفعل في مخزونك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This VIN is already in your inventory."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このVINはすでに在庫に登録されています。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот VIN уже есть в вашем инвентаре."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu VIN allaqachon inventaringizga kiritilgan."
          }
        }
      }
    },
    "This will permanently delete your account and all data." : {
      "comment" : "A description of what happens when the user deletes their account.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف حسابك وجميع البيانات بشكل دائم."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete your account and all data."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントとすべてのデータが完全に削除されます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это действие безвозвратно удалит ваш аккаунт и все данные."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu sizning hisobingiz va barcha maʻlumotlarni butunlay oʻchirib tashlaydi."
          }
        }
      }
    },
    "This will remove the debt and all its payments." : {
