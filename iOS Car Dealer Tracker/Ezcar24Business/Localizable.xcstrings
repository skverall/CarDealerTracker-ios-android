    "guest_preview_vehicles_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بمعاينة بطاقات المخزون ورؤية التكلفة وتتبع الحالة والاستعداد للبيع دون حفظ المركبات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preview inventory cards, cost visibility, status tracking, and sale readiness without saving vehicles."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कारों को सहेजे बिना इन्वेंट्री कार्ड, लागत दृश्यता, स्थिति ट्रैकिंग और बिक्री की तैयारी का पूर्वावलोकन करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pratinjau kartu inventaris, visibilitas biaya, pelacakan status, dan kesiapan penjualan tanpa menyimpan kendaraan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "車両を保存せずに、在庫カード、原価表示、ステータス管理、販売準備状況を確認できます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visualize cartões de estoque, visibilidade de custos, rastreamento de status e disponibilidade de venda sem salvar veículos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Посмотрите карточки авто, себестоимость, статусы и готовность к продаже без сохранения машин."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avtomobillarni saqlamasdan inventar kartalarini, xarajatlar koʻrinishini, holatni kuzatish va sotishga tayyorligini koʻrib chiqing."
          }
        }
      }
    },
