        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने वास्तविक गोदाम को लोड करने से पहले स्टॉक स्तर, कम स्टॉक अलर्ट और आंशिक बिक्री का पूर्वावलोकन करें।"
