        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стоимость хранения составляет %@%% от общей стоимости. Рассмотрите более быстрый оборот."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saqlash xarajati umumiy xarajatning %@%% qismini tashkil qiladi. Tezroq aylanishni ko‘rib chiqing."
          }
        }
      }
    },
