    "feedback_board_intro_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انشر فكرة واضحة واحدة، ثم صوّت لطلبات التجار الآخرين."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Post one clear idea, then vote on requests from other dealers."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक स्पष्ट विचार पोस्ट करें, फिर अन्य डीलरों के अनुरोध पर वोट करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posting satu ide yang jelas, lalu pilih permintaan dari dealer lain."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "わかりやすいアイデアを投稿し、他の販売店の要望に投票できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "명확한 아이디어 하나를 올리고 다른 딜러의 요청에 투표하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poste uma ideia clara e depois vote nas solicitações de outros revendedores."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опишите одну понятную идею и голосуйте за предложения других дилеров."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitta aniq gʻoya yozing, keyin boshqa dilerlar soʻrovlariga ovoz bering."
          }
        }
      }
    },
    "feedback_board_intro_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
