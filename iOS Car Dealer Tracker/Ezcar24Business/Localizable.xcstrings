    "Holding cost is %@%% of total cost. Consider faster turnover." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تكلفة الاحتفاظ تمثل %@%% من إجمالي التكلفة. فكّر في تسريع دوران المخزون."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Holding cost is %@%% of total cost. Consider faster turnover."
