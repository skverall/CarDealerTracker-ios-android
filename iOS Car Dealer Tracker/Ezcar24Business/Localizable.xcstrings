    "guest_preview_parts_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بمعاينة مستويات المخزون وتنبيهات انخفاض المخزون والمبيعات الجزئية قبل تحميل مستودعك الحقيقي."
