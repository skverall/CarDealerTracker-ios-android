    "edit_profile_email_change_partial_failure" : {
      "comment" : "Profile save error after email change request succeeds but profile save fails.",
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم طلب تغيير البريد الإلكتروني، ولكن تعذر حفظ بقية الملف الشخصي. أعد فتح الملف الشخصي وتحقق من التفاصيل."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Email change was requested, but the rest of the profile could not be saved. Reopen the profile and verify the details."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ईमेल परिवर्तन का अनुरोध किया गया था, लेकिन शेष Proफ़ाइल सहेजी नहीं जा सकी. Proफ़ाइल को दोबारा खोलें और विवरण सत्यापित करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perubahan email telah diminta, namun profil lainnya tidak dapat disimpan. Buka kembali profil dan verifikasi detailnya."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メール変更はリクエストされましたが、その他のプロフィール情報を保存できませんでした。プロフィールを開き直して内容を確認してください。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A alteração do e-mail foi solicitada, mas o restante do perfil não pôde ser salvo. Abra novamente o perfil e verifique os detalhes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запрос на смену email отправлен, но остальные данные профиля не удалось сохранить. Откройте профиль снова и проверьте данные."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "E-pochtani oʻzgartirish soʻraldi, lekin profilning qolgan qismini saqlab boʻlmadi. Profilni qayta oching va tafsilotlarni tekshiring."
          }
        }
      }
    },
