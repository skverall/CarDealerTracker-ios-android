    "1. Ask team admin for the Team Invite Code.": {
      "comment": "A step in the process of joining a team, describing the first action to take.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1. チーム管理者にチーム招待コードを確認してください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Попросите администратора команды дать код приглашения."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Ask team admin for the Team Invite Code."
          }
        }
      }
    },
    "2. Enter code below and tap Join Team.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "2. 下にコードを入力し、「チームに参加」をタップします。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Введите код ниже и нажмите «Вступить в команду»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Enter code below and tap Join Team."
          }
        }
      }
    },
