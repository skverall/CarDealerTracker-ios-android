    "Supabase rejects gmail addresses shorter than 6 characters before the @. Add characters before @ or use another email." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرفض Supabase عناوين gmail التي يقل الجزء قبل @ فيها عن 6 أحرف. أضف أحرفًا قبل @ أو استخدم بريدًا إلكترونيًا آخر."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supabase rejects gmail addresses shorter than 6 characters before the @. Add characters before @ or use another email."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supabase @ से पहले 6 अक्षर से छोटे जीमेल पते को अस्वीकार करता है। @ से पहले अक्षर जोड़ें या किसी अन्य ईमेल का उपयोग करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supabase は @ の前が6文字未満の gmail アドレスを拒否します。@ の前に文字を追加するか、別のメールを使用してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supabase отклоняет gmail-адреса короче 6 символов перед @. Добавьте символы перед @ или используйте другой email."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supabase @ belgisidan oldin 6 belgidan qisqa gmail manzillarini rad etadi. @ dan oldin belgilar qoʻshing yoki boshqa email ishlating."
          }
        }
      }
    },
