          "stringUnit" : {
            "state" : "translated",
            "value" : "कारों को सहेजे बिना इन्वेंट्री कार्ड, लागत दृश्यता, स्थिति ट्रैकिंग और बिक्री की तैयारी का पूर्वावलोकन करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "車両を保存せずに、在庫カード、原価表示、ステータス管理、販売準備状況を確認できます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Посмотрите карточки авто, себестоимость, статусы и готовность к продаже без сохранения машин."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avtomobillarni saqlamasdan inventar kartalarini, xarajatlar koʻrinishini, holatni kuzatish va sotishga tayyorligini koʻrib chiqing."
          }
        }
      }
    },
